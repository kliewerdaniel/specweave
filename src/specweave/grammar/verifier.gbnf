root ::= json-object
json-object ::= "{" ws pair (ws "," ws pair)* ws "}"
pair ::= string ws ":" ws value
string ::= "\"" [^"]* "\""
value ::= string | number | json-object | json-array | "true" | "false" | "null"
number ::= "-"? ("0" | [1-9] [0-9]*) ("." [0-9]+)? ([eE] [+-]? [0-9]+)?
json-array ::= "[" ws [value (ws "," ws value)*] ws "]"
ws ::= [ \t\n\r]*
